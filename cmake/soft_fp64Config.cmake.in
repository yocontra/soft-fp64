@PACKAGE_INIT@

# soft_fp64 is a self-contained static library — no transitive dependencies.
# Pull in the exported targets and confirm components.

include("${CMAKE_CURRENT_LIST_DIR}/soft_fp64Targets.cmake")

# Source-tree variables for consumers that need to compile the `sf64_*`
# bodies themselves (e.g. AdaptiveCpp's libkernel bitcode build globs
# these `.cpp` files directly into a SYCL/SSCP target). Resolved against
# the install prefix; both paths are absolute after PACKAGE_INIT.
set_and_check(soft_fp64_SOURCE_DIR        "@PACKAGE_SOFT_FP64_SOURCE_RELDIR@")
set_and_check(soft_fp64_SLEEF_SOURCE_DIR  "@PACKAGE_SOFT_FP64_SLEEF_SOURCE_RELDIR@")
set_and_check(soft_fp64_INCLUDE_DIR       "@PACKAGE_SOFT_FP64_INCLUDE_RELDIR@")

check_required_components(soft_fp64)
